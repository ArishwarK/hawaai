{
  "version": 2,
  "env": { "SUPABASE_URL": "https://ycgktkdudxazftgbizlw.supabase.co", "SUPABASE_KEY": "sb_publishable_MKn7eVJ-99gkPBkq5XYQ1w_wLaJ1T8J", "ADMIN_PASSWORD": "hawaai#2026" },
  "builds": [
    {
      "src": "hawaiian-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*\\..*)",
