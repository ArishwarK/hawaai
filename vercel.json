{
  "version": 2,
  "builds": [
    {
      "src": "hawaiian-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "/hawaiian-app/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/hawaiian-app/index.html"
    }
  ]
}
